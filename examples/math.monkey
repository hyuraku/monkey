// Math operations example
// This demonstrates mathematical built-in functions and float support

puts("Math operations:");

puts("Absolute values:");
puts(abs(-42));
puts(abs(3.14));

puts("Min and Max:");
puts(min(5, 3));
puts(max(5, 3));

puts("Square root:");
puts(sqrt(16));
puts(sqrt(2));

puts("Float operations:");
let pi = 3.14159;
let radius = 5.0;
let area = pi * radius * radius;
puts(area);

puts("Mixed integer and float:");
let mixed = 10 + 5.5;
puts(mixed);
